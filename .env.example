# Example .env file for nanobot (Docker/cloud)
# Copy to .env and fill in your values

# === LLM PROVIDER (OpenRouter recommended) ===
NANOBOT_PROVIDERS__OPENROUTER__APIKEY=sk-or-v1-xxx
#NANOBOT_PROVIDERS__OPENROUTER__API_BASE=https://openrouter.ai/api/v1
#NANOBOT_PROVIDERS__OPENROUTER__MODEL=anthropic/claude-opus-4-5

# === AGENT DEFAULTS ===
NANOBOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-opus-4-5
NANOBOT_AGENTS__DEFAULTS__PROVIDER=openrouter
NANOBOT_AGENTS__DEFAULTS__WORKSPACE=/root/.nanobot/workspace
NANOBOT_AGENTS__DEFAULTS__TIMEZONE=UTC

# === GATEWAY ===
NANOBOT_GATEWAY__PORT=18790
NANOBOT_GATEWAY__HOST=0.0.0.0

# === TELEGRAM CHANNEL (optional) ===
#NANOBOT_CHANNELS__TELEGRAM__ENABLED=true
#NANOBOT_CHANNELS__TELEGRAM__TOKEN=your-telegram-bot-token
#NANOBOT_CHANNELS__TELEGRAM__ALLOWFROM=*

# === DISCORD CHANNEL (optional) ===
#NANOBOT_CHANNELS__DISCORD__ENABLED=true
#NANOBOT_CHANNELS__DISCORD__TOKEN=your-discord-bot-token

# === EMAIL CHANNEL (optional) ===
#NANOBOT_CHANNELS__EMAIL__ENABLED=true
#NANOBOT_CHANNELS__EMAIL__IMAPHOST=imap.gmail.com
#NANOBOT_CHANNELS__EMAIL__IMAPUSERNAME=your@email.com
#NANOBOT_CHANNELS__EMAIL__IMAPPASSWORD=your-app-password

# === WEB SEARCH (optional) ===
#NANOBOT_TOOLS__WEB__SEARCH__PROVIDER=duckduckgo
#NANOBOT_TOOLS__WEB__SEARCH__APIKEY=your-api-key

# === LOGGING ===
#NANOBOT_LOG_LEVEL=INFO
